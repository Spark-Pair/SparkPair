# MongoDB
MONGODB_URI=
MONGODB_DB=sparkpair
# Optional local DNS override for Atlas SRV lookup issues on Windows.
# Example: MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
MONGODB_DNS_SERVERS=

# Admin
SPARKPAIR_ADMIN_PASSWORD=

# Release sync from GarmentsOS PRO EXP GitHub Actions
RELEASE_WEBHOOK_SECRET=

# License key hashing secret/pepper
LICENSE_KEY_PEPPER=

# Site URL
NEXT_PUBLIC_SITE_URL=https://sparkpair.dev

# Optional GitHub metadata
GITHUB_RELEASE_OWNER=Spark-Pair
GITHUB_RELEASE_REPO=garmentsos-pro-experiment
GITHUB_RELEASE_TOKEN=
RELEASE_DOWNLOAD_MODE=storage_or_github_proxy

# Cloudinary media uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=sparkpair/products
CLOUDINARY_MAX_IMAGE_MB=5
CLOUDINARY_MAX_VIDEO_MB=50
