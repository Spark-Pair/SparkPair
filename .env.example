# MongoDB
# Vercel production may use either:
# - mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/sparkpair?retryWrites=true&w=majority
# - mongodb://host1:27017,host2:27017,host3:27017/sparkpair?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=sparkpair
# Optional local DNS override for Atlas SRV lookup issues on Windows.
# Usually leave this empty on Vercel unless you explicitly need custom resolvers.
# Example: MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
MONGODB_DNS_SERVERS=

# Admin
SPARKPAIR_ADMIN_PASSWORD=
# Stable signing secret for hosted admin sessions. Keep unchanged across deploys.
SPARKPAIR_ADMIN_SESSION_SECRET=

# Release sync from GarmentsOS PRO GitHub Actions
RELEASE_WEBHOOK_SECRET=

# License key hashing secret/pepper
LICENSE_KEY_PEPPER=

# Site URL
NEXT_PUBLIC_SITE_URL=https://www.sparkpair.dev

# Optional GitHub metadata
GITHUB_RELEASE_OWNER=Spark-Pair
GITHUB_RELEASE_REPO=garmentsos-pro

# Cloudinary media uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=sparkpair/products
CLOUDINARY_MAX_IMAGE_MB=5
CLOUDINARY_MAX_VIDEO_MB=50
